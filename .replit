modules = ["python-3.12", "bash"]
run = "uvicorn undefined:app --host 0.0.0.0 --port 3000"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "streamlit run streamlit_app.py --server.port 3000 --server.address 0.0.0.0 --server.headless true"]

[workflows]
runButton = "Streamlit"

[[workflows.workflow]]
name = "FastAPI"
author = 23072300

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app.main:app --host 0.0.0.0 --port 3000"

[[workflows.workflow]]
name = "Test Rewriter"
author = 23072300

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_rewriter.py"

[[workflows.workflow]]
name = "Streamlit"
author = 23072300

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run streamlit_app.py --server.address 0.0.0.0 --server.port 3000"

[[ports]]
localPort = 3000
externalPort = 80
